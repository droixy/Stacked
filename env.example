# ──────────────────────────────────────────────
# StudyAI Backend - Environment Variables
# Copy this to .env and fill in your real keys
# ──────────────────────────────────────────────

# Server
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ── AI API Keys ──
OPENAI_API_KEY=sk-...               # GPT-5 Mini (ChatGPT)
PERPLEXITY_API_KEY=pplx-...         # Perplexity AI
ANTHROPIC_API_KEY=sk-ant-...        # Claude AI
TURBO_API_KEY=your-turbo-key        # Turbo AI
WOLFRAM_APP_ID=your-wolfram-app-id  # Wolfram Alpha

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STUDENT_PRICE_ID=price_...   # $9/mo Student plan price ID
STRIPE_PRO_PRICE_ID=price_...       # $29/mo Pro plan price ID
